{
  "name": "izma-app",
  "module": "index.ts",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "private": true,
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "dev:server": "bun --env-file apps/server/.env --watch apps/server/src/index.ts",
    "build:web": "bun run --cwd apps/web build",
    "lint": "bunx biome check .",
    "format": "bunx biome format . --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}